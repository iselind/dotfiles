#!/bin/bash
# Only run for interactive bash shells
if [[ $- != *i* ]]; then
	return 0 2>/dev/null || exit 0
fi
# An alternative to the above
# [[ $- != *i* ]] && return

# Prompt: show host, working dir, and mark failed last command
PS1='$(if [ $? -ne 0 ]; then echo "[FAIL] "; fi)\h:\w\$ '

## Don't set vi mode, that screws up the Ctrl+l mapping
## Instead we should prefer the emacs mode in the terminal
## Use vim keybindings (like `bindkey -v` in zsh)
#set -o vi
set -o emacs

# History
HISTSIZE=1000
HISTFILESIZE=1000
HISTFILE=~/.bash_history

# Enable system bash completions if available
if [ -f /etc/bash_completion ]; then
	# shellcheck disable=SC1091
	. /etc/bash_completion
fi

# Terminfo / LS colors
eval "$(dircolors -b)"

# Aliases
alias ls='ls -F'
alias bt_battery="bluetooth_battery 34:75:63:DA:AA:C5"

YARN_PATH=$(yarn global bin)

# Environment
export PYSPARK_PYTHON=python3
export PYSPARK_DRIVER_PYTHON=${PYSPARK_PYTHON}
export LESS=dMQifRF
export LESSCHARSET=utf-8
export GOPATH="$HOME/go-packages"
export GOROOT="$HOME/go"
export PATH=$YARN_PATH:$HOME/.pipinstall/bin:$GOROOT/bin:$GOPATH/bin:/usr/local/go/bin:$HOME/.local/bin:$HOME/code/dotfiles/shell/bin:$PATH

# Notices
[ -f /var/run/reboot-required ] && echo "System needs to reboot!"

# Kill the bell
xset -b

# ripgrep->fzf->vim helper
# For file contents searching
rfv() {
	RELOAD='reload:rg --column --color=always --smart-case {q} || :'
	OPENER='if [[ $FZF_SELECT_COUNT -eq 0 ]]; then
						vim {1} +{2}
					else
						vim +cw -q {+f}
					fi'
	fzf --disabled --ansi --multi \
			--bind "start:$RELOAD" --bind "change:$RELOAD" \
			--bind "enter:become:$OPENER" \
			--bind "ctrl-o:execute:$OPENER" \
			--bind 'alt-a:select-all,alt-d:deselect-all,ctrl-/:toggle-preview' \
			--delimiter : \
			--preview 'batcat --style=full --color=always --highlight-line {2} {1}' \
			--preview-window '~4,+{2}+4/3,<80(up)' \
			--query "$*"
}

# fdfind->fzf->vim helper
# For file name searching
ffv() {
    fdfind | fzf --preview 'batcat {}'
}

#######################
# Git helpers
#######################

prune_branches() {
    # We assume that this function is executed within a git repo.

    local original_dir main_wt
    original_dir=$(pwd)
    main_wt=$(git worktree list --porcelain | head -1 | cut -d' ' -f2-)

    # Operate from the main worktree so we can remove any linked worktree freely.
    cd "$main_wt" || return 1

    # Fetch and prune so upstream tracking status is accurate.
    git fetch --prune

    # If the main worktree's branch has a gone upstream, switch to main so we can delete it below.
    local mwt_branch mwt_upstream
    mwt_branch=$(git branch --show-current)
    mwt_upstream=$(git for-each-ref --format='%(upstream:track)' "refs/heads/$mwt_branch")
    if [[ "$mwt_upstream" == "[gone]" ]]; then
        local main_linked_wt
        main_linked_wt=$(git for-each-ref --format='%(worktreepath)' refs/heads/main)
        if [[ -n "$main_linked_wt" ]]; then
            echo "Main worktree branch '$mwt_branch' upstream is gone but main is checked out at $main_linked_wt — cannot switch; $mwt_branch will not be deleted."
        else
            echo "Main worktree branch '$mwt_branch' upstream is gone; switching to main."
            git checkout main && git pull
        fi
    fi

    # Prune local branches whose upstream is gone.
    # For linked worktrees, remove the worktree then delete the branch.
    # For regular (non-checked-out) branches, just delete.
    # Use | as delimiter so empty %(upstream:track) doesn't shift %(worktreepath) into the wrong field.
    git for-each-ref --format='%(refname:short)|%(upstream:track)|%(worktreepath)' refs/heads/ | \
        while IFS='|' read -r branch upstream worktree; do
            if [[ "$upstream" != "[gone]" ]]; then
                continue
            fi
            if [[ -n "$worktree" && "$worktree" != "$main_wt" ]]; then
                echo "Removing worktree $worktree (branch $branch upstream is gone)."
                if git worktree remove "$worktree"; then
                    git branch -D "$branch"
                else
                    echo "Could not remove $worktree — skipping (may have uncommitted changes)."
                fi
            elif [[ -z "$worktree" ]]; then
                git branch -D "$branch"
            fi
        done

    # Return to the original directory if it still exists; otherwise stay in the main worktree.
    if [[ -d "$original_dir" ]]; then
        cd "$original_dir"
    else
        echo "Original worktree $original_dir was removed; staying in $main_wt."
    fi
}

#######################
# Kubernetes helpers
#######################

alias k=kubectl

kns() {
    if [ -z "$1" ]; then
        kubectl get namespaces
    else
        kubectl config set-context --current --namespace="$1"
    fi
}

kctx() {
    if [ -z "$1" ]; then
        kubectl config get-contexts | sed -e 's/  \+/ /g' | cut -d' ' -f-2
    else
        kubectl config use-context "$1"
    fi
}
