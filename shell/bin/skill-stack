#!/usr/bin/env bash
set -euo pipefail

# skill-stack — manage the Claude skill invocation stack
#
# Usage:
#   skill-stack push <skill> [resume]   Push a frame onto the stack.
#                                       <resume> is a single address describing
#                                       exactly where to pick up work in <skill>
#                                       once the invoked sub-skill returns — a
#                                       phase name, step label, or any marker that
#                                       unambiguously identifies the resumption
#                                       point. It need not be a phase boundary.
#                                       Omit for terminal skills with no remaining
#                                       work after the sub-skill returns.
#   skill-stack pop                     Pop the top frame. If the stack is still
#                                       non-empty, prints the caller frame's resume
#                                       as a "Returning to <skill> — <resume>" line.
#                                       Silent when the last frame is popped.
#                                       Deletes the stack file when empty.
#   skill-stack peek                    Print the top frame without removing it.
#   skill-stack show                    Print the full stack (bottom to top).
#   skill-stack clear                   Delete the stack file.
#
# The stack is scoped to the current working directory + git branch, stored as:
#   ~/.cache/claude/skill-stack/<slugified-pwd>/<slugified-branch>.json
#
# Frame format: {"skill": "<name>", "resume": "<single resumption address>"}
# Top of stack = last element in the JSON array.

slugify() {
    echo "$1" | sed 's|^/||; s|/|-|g; s|[^a-zA-Z0-9._-]|-|g'
}

stack_file() {
    local pwd_slug branch branch_slug
    pwd_slug="$(slugify "$(pwd)")"
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "no-branch")"
    branch_slug="$(slugify "$branch")"
    echo "${HOME}/.cache/claude/skill-stack/${pwd_slug}/${branch_slug}.json"
}

ensure_file() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        mkdir -p "$(dirname "$file")"
        echo "[]" > "$file"
    fi
}

cmd="${1:-}"
case "$cmd" in
    push)
        skill="${2:?Usage: skill-stack push <skill> [resume]}"
        resume="${3:-}"
        file="$(stack_file)"
        ensure_file "$file"
        jq --arg skill "$skill" --arg resume "$resume" \
            '. += [{"skill": $skill, "resume": $resume}]' "$file" > "${file}.tmp"
        mv "${file}.tmp" "$file"
        ;;
    pop)
        file="$(stack_file)"
        if [[ ! -f "$file" ]] || [[ "$(cat "$file")" == "[]" ]]; then
            echo "skill-stack: stack is empty" >&2
            exit 1
        fi
        # Read the resume from the frame being popped — set by the callee's Phase 0
        popped_resume="$(jq -r 'last.resume' "$file")"
        jq 'if length <= 1 then [] else .[:-1] end' "$file" > "${file}.tmp"
        mv "${file}.tmp" "$file"
        # Announce return to caller using caller's skill name + popped frame's resume
        if [[ "$(cat "$file")" != "[]" ]]; then
            caller_skill="$(jq -r 'last.skill' "$file")"
            if [[ -n "$popped_resume" ]]; then
                echo "Returning to ${caller_skill} — ${popped_resume}"
            else
                echo "Returning to ${caller_skill}"
            fi
        fi
        # Clean up empty stack
        if [[ "$(cat "$file")" == "[]" ]]; then
            rm "$file"
            rmdir --ignore-fail-on-non-empty "$(dirname "$file")"
        fi
        ;;
    peek)
        file="$(stack_file)"
        if [[ ! -f "$file" ]] || [[ "$(cat "$file")" == "[]" ]]; then
            echo "skill-stack: stack is empty" >&2
            exit 1
        fi
        jq -e 'last' "$file"
        ;;
    show)
        file="$(stack_file)"
        if [[ ! -f "$file" ]]; then
            echo "[]"
        else
            jq '.' "$file"
        fi
        ;;
    clear)
        file="$(stack_file)"
        if [[ -f "$file" ]]; then
            rm "$file"
            rmdir --ignore-fail-on-non-empty "$(dirname "$file")"
        fi
        ;;
    *)
        echo "Usage: skill-stack push <skill> <resume>" >&2
        echo "       skill-stack pop" >&2
        echo "       skill-stack peek" >&2
        echo "       skill-stack show" >&2
        echo "       skill-stack clear" >&2
        exit 1
        ;;
esac
