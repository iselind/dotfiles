{
  "coc.preferences.formatOnSaveFiletypes": [
    "go",
    "python",
    "sh",
    "terraform"
  ],
  "diagnostic": {
    "floatEnabled": true,
    "errorSign": "✖",
    "warningSign": "⚠",
    "infoSign": "ℹ",
    "hintSign": "💡",
    "logLevel": "debug"
  },
  "go": {
    "goplsOptions": {
      "completeUnimported": true,
      "usePlaceholders": true
    }
  },
  "languageserver": {
    "terraform": {
      "command": "terraform-ls",
      "args": [
        "serve"
      ],
      "filetypes": [
        "terraform",
        "tf"
      ],
      "initializationOptions": {},
      "settings": {}
    }
  }
}
